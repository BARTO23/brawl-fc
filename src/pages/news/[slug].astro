---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import newsData from "../../data/news.json";

export function getStaticPaths() {
  return newsData.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const categoryColors: Record<string, string> = {
  "Fichaje": "background: #FEBE20; color: #1a1a2e;",
  "Temporada": "background: #00E5FF; color: #1a1a2e;",
  "Balance": "background: #9B59B6; color: white;",
  "Partido": "background: #2CD730; color: #1a1a2e;",
  "Club": "background: #0ea5e9; color: white;",
};
const catColor = categoryColors[article.category] || "background: #4a4a7a; color: white;";
---

<Layout>
  <Header />
  <main class="max-w-3xl mx-auto px-8 md:px-4 py-8 text-center md:text-left">
    <div class="text-center md:text-left">
      <a href="/news" class="bs-btn bs-btn-sm mb-6">&larr; Volver a noticias</a>
    </div>
    <article>
      <div class="flex items-center justify-center sm:justify-start gap-2 mb-4">
        <span class="bs-tag font-display text-xs" style={catColor}>{article.category}</span>
        <span class="font-body text-gray-500 text-sm">{article.date}</span>
      </div>
      <h1 class="font-display text-3xl sm:text-4xl text-white mb-6 text-center sm:text-left" style="text-shadow: -1px 1px 0 black;">{article.title}</h1>
      <div class="bs-card p-6">
        <p class="font-body text-gray-300 leading-relaxed text-lg">{article.body}</p>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
