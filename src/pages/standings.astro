---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StandingsTable from "../components/StandingsTable.astro";
---

<Layout>
  <Header />
  <main class="max-w-4xl mx-auto px-8 md:px-4 py-8 text-center md:text-left">
    <h1 class="font-display text-3xl sm:text-4xl text-bs-yellow mb-2 text-center sm:text-left" style="text-shadow: -2px 2px 0 black;">Clasificación</h1>
    <p class="font-body text-gray-400 mb-8 text-center sm:text-left">Tabla de posiciones de la Club League</p>
    <StandingsTable />
  </main>
  <Footer />
</Layout>
